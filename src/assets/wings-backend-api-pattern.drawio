        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-111" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=22;fontStyle=1;arcSize=0;" value="6" vertex="1">
