        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-119" parent="1" style="sketch=0;pointerEvents=1;shadow=0;dashed=0;html=1;strokeColor=none;fillColor=#FFFFFF;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;outlineConnect=0;align=center;shape=mxgraph.office.devices.mac_client;" value="" vertex="1">
          <mxGeometry height="80" width="80" x="-10" y="100" as="geometry" />
