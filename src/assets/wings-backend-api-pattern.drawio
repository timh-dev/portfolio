        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-113" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=22;fontStyle=1;arcSize=0;" value="8" vertex="1">
          <mxGeometry height="25" width="26" x="824" y="370" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-114" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=22;fontStyle=1;arcSize=0;" value="9" vertex="1">
          <mxGeometry height="25" width="26" x="824" y="440" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-115" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=22;fontStyle=1;arcSize=0;" value="10" vertex="1">
          <mxGeometry height="25" width="26" x="824" y="538" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-116" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=22;fontStyle=1;arcSize=0;" value="11" vertex="1">
          <mxGeometry height="25" width="26" x="824" y="650" as="geometry" />
        </mxCell>
        <UserObject label="Amazon Route 53 resolves your domain (e.g., &lt;span class=&quot;s1&quot;&gt;api.company.com&lt;/span&gt;) to the correct entry point, typically a CloudFront distribution. Route 53 is strictly DNS; it has no awareness of authentication, authorization, or application logic." link="Amazon Route 53 resolves your domain (e.g., &lt;span class=&quot;s1&quot;&gt;api.company.com&lt;/span&gt;) to the correct entry point, typically a CloudFront distribution. Route 53 is strictly DNS; it has no awareness of authentication, authorization, or application logic." id="bT5xWx5P-uIQ1Ut-rW39-124">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="50" width="470" x="860" y="-85" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-125" parent="1" style="text;whiteSpace=wrap;html=1;" value="AWS WAF inspects incoming traffic before it reaches your application. It can block malicious IP addresses, apply rate limits, or filter known attack patterns.&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;" vertex="1">
          <mxGeometry height="50" width="470" x="860" y="-20" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-126" parent="1" style="text;whiteSpace=wrap;html=1;" value="Amazon CloudFront acts as your edge distribution layer. It terminates TLS, caches static assets, and routes requests. Requests for your frontend may go to S3, while &lt;span class=&quot;s1&quot;&gt;/api/*&lt;/span&gt; requests are forwarded to API Gateway." vertex="1">
          <mxGeometry height="65" width="480" x="860" y="45" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-129" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span class=&quot;s1&quot;&gt;Amazon S3 hosts your static frontend. When users load your application, CloudFront may retrieve static HTML, JS, and CSS files from S3. This layer is unrelated to API authentication but is part of the overall architecture.&lt;/span&gt;" vertex="1">
          <mxGeometry height="76.22" width="480" x="860" y="113.78" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-130" parent="1" style="text;whiteSpace=wrap;html=1;" value="Amazon Cognito handles user authentication. When a user logs in, Cognito verifies credentials and issues a signed JWT access token. That token contains claims such as user ID, group membership, scopes, expiration time, issuer, and audience." vertex="1">
          <mxGeometry height="66.22" width="480" x="860" y="183.78" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-132" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span class=&quot;s1&quot;&gt;Amazon API Gateway enforces authentication by validating JWT tokens from Cognito. When a request arrives, API Gateway extracts the JWT, verifies its cryptographic signature, and checks issuer, audience, and expiration. If validation fails, the request is rejected with a 401 before reaching Lambda. If successful, the request is forwarded to Lambda, ensuring only authenticated users trigger backend execution. API Gateway confirms token validity but does not handle resource-level authorization.&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="470" x="860" y="250" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-133" parent="1" style="text;whiteSpace=wrap;html=1;" value="AWS Lambda receives the request only after API Gateway has validated the token. Lambda is responsible for running your application code, but it does not need to verify the JWT signature again unless you explicitly choose to. Each domain service (e.g., assets-service, risk-service) typically has its own Lambda function." vertex="1">
          <mxGeometry height="80" width="480" x="860" y="360" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-134" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span class=&quot;s1&quot;&gt;The client logs in with Cognito to get a token, then includes that token in every API request using the&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;Authorization: Bearer &amp;lt;token&amp;gt;&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt;&amp;nbsp;header. The client doesn&#39;t validate or inspect the token — it just stores it and sends it along.&lt;/span&gt;" vertex="1">
          <mxGeometry height="75" width="470" x="860" y="-155" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-137" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span class=&quot;s1&quot;&gt;&lt;a href=&quot;chatgpt://generic-entity?number=0&quot;&gt;Mangum&lt;/a&gt;&lt;/span&gt; acts as a translation layer between Lambda’s event format and FastAPI’s ASGI interface. Lambda receives requests in a structured JSON event format, but FastAPI expects ASGI-style HTTP requests. Mangum converts the Lambda event into something FastAPI understands, and converts the FastAPI response back into a Lambda-compatible response. Mangum does not perform authentication or authorization. It simply enables FastAPI to run inside Lambda." vertex="1">
          <mxGeometry height="95" width="480" x="860" y="435" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-139" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;span class=&quot;s1&quot;&gt;FastAPI receives the authenticated request with JWT claims and performs authorization by checking if the user has permission to access the specific resource. Authentication (handled by API Gateway) verifies the token is valid, while authorization (handled by FastAPI) verifies the user has the right scopes, groups, or permissions for the requested action. FastAPI also validates requests and formats responses.&lt;/span&gt;" vertex="1">
          <mxGeometry height="102" width="480" x="860" y="538" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-140" parent="1" style="text;whiteSpace=wrap;html=1;" value="&#xa;This is where persistent data lives created by the DBT process.&#xa;&#xa;&#xa;" vertex="1">
          <mxGeometry height="40" width="482" x="860" y="630" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-141" parent="1" style="text;whiteSpace=wrap;strokeWidth=0;fillColor=none;" value="A request flows through multiple AWS layers before reaching your application logic. Route 53 resolves the domain, WAF filters malicious traffic, and CloudFront handles TLS termination and routing. The client authenticates with Cognito to obtain a JWT token, which is included in every API request. API Gateway validates the token and rejects invalid requests before they reach Lambda, ensuring only authenticated users trigger compute. Lambda runs your FastAPI application via Mangum (an ASGI adapter), where authorization logic checks user permissions against specific resources. The business domain layer executes your core logic and interacts with data stores, with infrastructure access controlled by IAM roles. This separation ensures authentication happens at the gateway, authorization happens in the application, and business logic remains independent of AWS-specific constructs." vertex="1">
          <mxGeometry height="125" width="810" x="-56" y="-110" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-146" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=18;" value="Logging" vertex="1">
          <mxGeometry height="30" width="60" x="220" y="660" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-148" parent="1" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#FFFFFF;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;" value="CloudWatch" vertex="1">
          <mxGeometry height="78" width="78" x="110" y="700" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-149" parent="1" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#FFFFFF;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.xray;" value="XRay" vertex="1">
          <mxGeometry height="78" width="78" x="211" y="700" as="geometry" />
        </mxCell>
        <mxCell id="bT5xWx5P-uIQ1Ut-rW39-150" parent="1" style="sketch=0;outlineConnect=0;fontColor=#FFFFFF;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.cloudwatch_rum;" value="RUM" vertex="1">
          <mxGeometry height="78" width="78" x="310" y="700" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
